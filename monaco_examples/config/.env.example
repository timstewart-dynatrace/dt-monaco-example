# Dynatrace Monaco Configuration Migration - Environment Variables
# 
# Copy this file to .env and fill in your actual values
#

# SOURCE TENANT
# Dynatrace tenant URL (without trailing slash)
# Format: https://your-environment-id.live.dynatrace.com
SOURCE_TENANT_URL="https://your-source-tenant.live.dynatrace.com"

# API token for source tenant with these minimum scopes:
# - config.read
# - dashboards.read
SOURCE_TENANT_TOKEN="your_source_api_token_here"

# TARGET TENANT
# Dynatrace tenant URL (without trailing slash)
TARGET_TENANT_URL="https://your-target-tenant.live.dynatrace.com"

# API token for target tenant with these minimum scopes:
# - config.write
# - dashboards.write
# - alerting.write
# - settings.write
TARGET_TENANT_TOKEN="your_target_api_token_here"

# OPTIONAL SETTINGS

# Configuration directory (default: config)
# CONFIG_DIR=config

# Configuration types to migrate (comma-separated)
# If not set, all supported types will be migrated
# Available types:
# - alerting-profiles
# - app-detection-rule
# - auto-tag
# - calculated-metrics-log
# - calculated-metrics-service
# - dashboard
# - extension
# - management-zone
# - notification
# - settings
# - synthetic-monitor
# CONFIG_TYPES=dashboards,alerting-profiles,management-zone
