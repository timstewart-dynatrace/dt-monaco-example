# Environment variables - NEVER commit these
.env
.env.local
.env.*.local

# Secrets
.vscode/settings.json
secrets.yaml

# Configuration backups (only in monaco_examples/ and root config)
monaco_examples/config/backups/
monaco_examples/config/source/
monaco_examples/config/target/
monaco_examples/config/cloned-*/

# Cloned configurations (in monaco_examples/ only)
monaco_examples/cloned-*/

# Development workspace (ignore entire directory)
_workspace_dev/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
monaco_examples/**/*.log
_workspace_dev/**/*.log
monaco_migration/*.log
monaco_s2s_sua_migration/*.log

# Temporary files
tmp/
*.tmp

# OS
.DS_Store
Thumbs.db

# Standalone packages (monaco_migration/ and monaco_s2s_sua_migration/) have their own .gitignore
# Development workspace (_workspace_dev/) and examples (monaco_examples/) tracked separately
# Example directory (monaco_examples/) excludes runtime configs to keep repo clean
